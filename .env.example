# PostgreSQL — local dev / RDS in production
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ocb_platform"

# Auth.js v5 — generate: openssl rand -base64 32
AUTH_SECRET=""
# AUTH_URL is optional in dev (auto-detected); required in production
AUTH_URL="http://localhost:3000"

# Field-level AES-256-GCM encryption for SSN/DOB (GLBA)
# Generate: openssl rand -base64 32
PII_ENCRYPTION_KEY=""

# Shared secret authenticating the internal bureau report-fetch route
# (triggerReportFetch → POST /api/bureau/fetch). Generate: openssl rand -base64 32
INTERNAL_API_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Twilio SMS
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# AWS SES + S3
AWS_REGION="us-east-1"
S3_DOCUMENTS_BUCKET=""

# Credit monitoring partner API (Open Decision #1: SmartCredit / IdentityIQ)
CREDIT_MONITOR_API_KEY=""
